/* Split Panel Layout - Patient Dashboard */
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

.container {
  min-height: 100vh;
  background: #f5f7fa;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

/* Dashboard Layout */
.dashboardLayout {
  display: flex;
  height: calc(100vh - 64px);
  max-width: 1600px;
  margin: 0 auto;
}

/* Left Sidebar - Filters */
.sidebar {
  width: 280px;
  background: white;
  border-right: 1px solid #e5e7eb;
  overflow-y: auto;
  flex-shrink: 0;
}

.sidebarHeader {
  padding: 1.5rem;
  border-bottom: 1px solid #e5e7eb;
}

.welcomeSection {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.avatarCircle {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 1.125rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  flex-shrink: 0;
}

.sidebarTitle {
  font-size: 0.875rem;
  font-weight: 700;
  color: #111827;
  margin: 0 0 0.25rem 0;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.sidebarSubtitle {
  font-size: 0.75rem;
  color: #6b7280;
  margin: 0;
}

/* Search Section */
.searchSection {
  padding: 1rem;
  border-bottom: 1px solid #e5e7eb;
}

.searchBox {
  position: relative;
  display: flex;
  align-items: center;
}

.searchBox i {
  position: absolute;
  left: 12px;
  color: #9ca3af;
  font-size: 0.875rem;
}

.searchInput {
  width: 100%;
  padding: 0.625rem 2.5rem 0.625rem 2.5rem;
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  font-size: 0.875rem;
  font-family: 'Inter', sans-serif;
  transition: all 0.2s;
  background: #f9fafb;
}

.searchInput:focus {
  outline: none;
  border-color: #6366f1;
  background: white;
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
}

.searchInput::placeholder {
  color: #9ca3af;
}

.clearSearch {
  position: absolute;
  right: 8px;
  width: 24px;
  height: 24px;
  border: none;
  background: #e5e7eb;
  color: #6b7280;
  border-radius: 50%;
  cursor: pointer;
  font-size: 1.25rem;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.clearSearch:hover {
  background: #d1d5db;
  color: #374151;
}

/* Stats Section */
.statsSection {
  padding: 1rem;
  border-bottom: 1px solid #e5e7eb;
}

.statsCards {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.statCard {
  background: white;
  border: 1.5px solid #e5e7eb;
  border-radius: 8px;
  padding: 0.75rem 1rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: all 0.2s;
  cursor: pointer;
}

.statCard:hover {
  border-color: #6366f1;
  background: #f9fafb;
}

.statCard.active {
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  border-color: #6366f1;
  box-shadow: 0 2px 8px rgba(99, 102, 241, 0.15);
}

.statLeft {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.statIconBox {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.875rem;
  flex-shrink: 0;
}

.statIconBox.yellow {
  background: #fef3c7;
  color: #d97706;
}

.statIconBox.green {
  background: #d1fae5;
  color: #059669;
}

.statIconBox.blue {
  background: #dbeafe;
  color: #2563eb;
}

.statIconBox.red {
  background: #fee2e2;
  color: #dc2626;
}

.statLabel {
  font-size: 0.875rem;
  color: #374151;
  font-weight: 500;
}

.statCount {
  font-size: 1.125rem;
  font-weight: 700;
  color: #111827;
  min-width: 28px;
  text-align: right;
}

.statContent h4 {
  font-size: 0.75rem;
  color: #6b7280;
  margin: 0 0 0.25rem 0;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.statContent p {
  font-size: 1.5rem;
  font-weight: 700;
  color: #111827;
  margin: 0;
}

/* Status Filters */
.filterSection {
  padding: 1rem;
  border-bottom: 1px solid #e5e7eb;
}

.filterTitle {
  font-size: 0.75rem;
  font-weight: 600;
  color: #6b7280;
  margin: 0 0 0.75rem 0;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* Doctors List */
.doctorsList {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  max-height: 300px;
  overflow-y: auto;
}

.doctorsList::-webkit-scrollbar {
  width: 6px;
}

.doctorsList::-webkit-scrollbar-track {
  background: #f3f4f6;
  border-radius: 3px;
}

.doctorsList::-webkit-scrollbar-thumb {
  background: #d1d5db;
  border-radius: 3px;
}

.doctorsList::-webkit-scrollbar-thumb:hover {
  background: #9ca3af;
}

.doctorItem {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem;
  border-radius: 6px;
  cursor: pointer;
  transition: all 0.15s;
  border: 1.5px solid transparent;
}

.doctorItem:hover {
  background: #f9fafb;
  border-color: #e5e7eb;
}

.doctorItem.active {
  background: #eff6ff;
  border-color: #6366f1;
}

.doctorAvatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 600;
  flex-shrink: 0;
}

.doctorInfo {
  flex: 1;
  min-width: 0;
}

.doctorName {
  font-size: 0.875rem;
  font-weight: 600;
  color: #111827;
  margin: 0 0 0.125rem 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.doctorSpec {
  font-size: 0.75rem;
  color: #6b7280;
  margin: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.doctorCount {
  font-size: 0.875rem;
  font-weight: 600;
  color: #6b7280;
  background: #f3f4f6;
  padding: 0.25rem 0.5rem;
  border-radius: 12px;
  min-width: 28px;
  text-align: center;
}

.doctorItem.active .doctorCount {
  background: #dbeafe;
  color: #2563eb;
}

/* Sort Select */
.sortSelect {
  width: 100%;
  padding: 0.625rem 0.75rem;
  border: 1.5px solid #e5e7eb;
  border-radius: 8px;
  font-size: 0.875rem;
  font-family: 'Inter', sans-serif;
  color: #374151;
  background: white;
  cursor: pointer;
  transition: all 0.2s;
}

.sortSelect:hover {
  border-color: #6366f1;
  background: #f9fafb;
}

.sortSelect:focus {
  outline: none;
  border-color: #6366f1;
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
}

/* Main Content Area */
.mainContent {
  flex: 1;
  overflow-y: auto;
  background: #fafbfc;
}

.contentHeader {
  background: white;
  border-bottom: 1px solid #e5e7eb;
  padding: 1.5rem 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 10;
}

.headerLeft h1 {
  font-size: 1.5rem;
  font-weight: 700;
  color: #111827;
  margin: 0 0 0.25rem 0;
}

.headerLeft p {
  font-size: 0.875rem;
  color: #6b7280;
  margin: 0;
}

.headerActions {
  display: flex;
  gap: 0.75rem;
  align-items: center;
}

/* Notification Button */
.notificationWrapper {
  position: relative;
}

.notificationBtn {
  width: 40px;
  height: 40px;
  background: white;
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.15s;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
  position: relative;
}

.notificationBtn:hover {
  background: #eff6ff;
  border-color: #6366f1;
  color: #6366f1;
}

.notificationBadge {
  position: absolute;
  top: -4px;
  right: -4px;
  background: #dc2626;
  color: white;
  font-size: 10px;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: 10px;
  min-width: 18px;
  text-align: center;
}

.notificationDropdown {
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  width: 380px;
  max-height: 500px;
  background: white;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.12);
  z-index: 1000;
  overflow: hidden;
}

.notificationHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  border-bottom: 1px solid #f3f4f6;
  background: #f9fafb;
}

.notificationHeader h3 {
  font-size: 16px;
  font-weight: 700;
  color: #111827;
  margin: 0;
}

.markAllRead {
  background: none;
  border: none;
  color: #6366f1;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  padding: 4px 8px;
  border-radius: 4px;
  transition: all 0.2s;
  font-family: 'Inter', sans-serif;
}

.markAllRead:hover {
  background: #eff6ff;
}

.notificationList {
  max-height: 400px;
  overflow-y: auto;
}

.notificationItem {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 16px 20px;
  border-bottom: 1px solid #f3f4f6;
  cursor: pointer;
  transition: all 0.2s;
}

.notificationItem:hover {
  background: #f9fafb;
}

.notificationRead {
  opacity: 0.6;
}

.notificationIcon {
  font-size: 24px;
  flex-shrink: 0;
}

.notificationContent {
  flex: 1;
}

.notificationContent h4 {
  font-size: 14px;
  font-weight: 600;
  color: #111827;
  margin: 0 0 4px 0;
}

.notificationContent p {
  font-size: 13px;
  color: #6b7280;
  margin: 0 0 6px 0;
}

.notificationTime {
  font-size: 11px;
  color: #9ca3af;
}

.unreadDot {
  width: 8px;
  height: 8px;
  background: #6366f1;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 6px;
}

.noNotifications {
  text-align: center;
  padding: 40px 20px;
}

.noNotifications span {
  font-size: 48px;
  display: block;
  margin-bottom: 12px;
  opacity: 0.3;
}

.noNotifications p {
  font-size: 14px;
  color: #6b7280;
  margin: 0;
}

/* Buttons */
.btnPrimary {
  padding: 0.625rem 1.25rem;
  background: #6366f1;
  color: white;
  border: none;
  border-radius: 8px;
  font-size: 0.875rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: 'Inter', sans-serif;
}

.btnPrimary:hover {
  background: #4f46e5;
}

/* Appointments List */
.appointmentsList {
  padding: 1.5rem 2rem;
}

.appointmentItem {
  background: white;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  margin-bottom: 1rem;
  overflow: hidden;
  transition: all 0.2s;
}

.appointmentItem:hover {
  border-color: #6366f1;
  box-shadow: 0 4px 12px rgba(99, 102, 241, 0.1);
}

.appointmentHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.25rem 1.5rem;
  cursor: pointer;
  transition: background 0.15s;
}

.appointmentHeader:hover {
  background: #f9fafb;
}

.appointmentLeft {
  display: flex;
  align-items: center;
  gap: 1rem;
  flex: 1;
}

.appointmentAvatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.125rem;
  font-weight: 600;
  flex-shrink: 0;
}

.appointmentInfo {
  flex: 1;
}

.appointmentDoctor {
  font-size: 1rem;
  font-weight: 600;
  color: #111827;
  margin: 0 0 0.25rem 0;
}

.appointmentSpec {
  font-size: 0.875rem;
  color: #6b7280;
  margin: 0;
}

.appointmentRight {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

.appointmentDateTime {
  text-align: right;
}

.appointmentDate {
  font-size: 0.875rem;
  font-weight: 600;
  color: #111827;
  margin: 0 0 0.25rem 0;
}

.appointmentTime {
  font-size: 0.875rem;
  color: #6b7280;
  margin: 0;
}

.statusBadge {
  padding: 0.375rem 0.875rem;
  border-radius: 9999px;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.025em;
}

.statusPending {
  background: #fef3c7;
  color: #92400e;
}

.statusConfirmed {
  background: #d1fae5;
  color: #065f46;
}

.statusCompleted {
  background: #dbeafe;
  color: #1e40af;
}

.statusRejected {
  background: #fee2e2;
  color: #991b1b;
}

.statusToday {
  background: #fef3c7;
  color: #92400e;
}

.statusUpcoming {
  background: #eff6ff;
  color: #1e40af;
}

.expandBtn {
  width: 32px;
  height: 32px;
  border-radius: 6px;
  border: 1px solid #e5e7eb;
  background: white;
  color: #6b7280;
  cursor: pointer;
  transition: all 0.15s;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.875rem;
}

.expandBtn:hover {
  background: #f9fafb;
  border-color: #6366f1;
  color: #6366f1;
}

/* Appointment Details (Expanded) */
.appointmentDetails {
  padding: 1.5rem;
  background: #f9fafb;
  border-top: 1px solid #e5e7eb;
}

.detailsGrid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
  margin-bottom: 1.5rem;
}

.detailItem {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.detailIcon {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6366f1;
  flex-shrink: 0;
}

.detailContent {
  flex: 1;
}

.detailLabel {
  font-size: 0.75rem;
  color: #6b7280;
  margin: 0 0 0.125rem 0;
  font-weight: 500;
}

.detailValue {
  font-size: 0.875rem;
  color: #111827;
  font-weight: 600;
  margin: 0;
}

/* Action Buttons */
.actionButtons {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.btnDownload,
.btnUpload,
.btnCancel {
  padding: 0.625rem 1.25rem;
  border-radius: 8px;
  font-size: 0.875rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: 'Inter', sans-serif;
  border: none;
}

.btnDownload {
  background: #dbeafe;
  color: #1e40af;
}

.btnDownload:hover {
  background: #3b82f6;
  color: white;
}

.btnUpload {
  background: #d1fae5;
  color: #065f46;
}

.btnUpload:hover {
  background: #10b981;
  color: white;
}

.btnCancel {
  background: #fee2e2;
  color: #991b1b;
}

.btnCancel:hover {
  background: #dc2626;
  color: white;
}

/* Reports Section */
.reportsSection {
  margin-top: 1rem;
  padding: 1rem;
  background: white;
  border-radius: 8px;
  border: 1px solid #e5e7eb;
}

.reportsTitle {
  font-size: 0.875rem;
  font-weight: 600;
  color: #374151;
  margin: 0 0 0.75rem 0;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.reportsList {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.reportItem {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem;
  background: #f9fafb;
  border-radius: 6px;
  border: 1px solid #e5e7eb;
}

.reportInfo {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex: 1;
}

.reportName {
  font-size: 0.875rem;
  font-weight: 500;
  color: #111827;
}

.reportDate {
  font-size: 0.75rem;
  color: #6b7280;
  margin-left: auto;
  margin-right: 0.75rem;
}

.btnDownloadReport {
  padding: 0.5rem;
  background: #6366f1;
  color: white;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  transition: all 0.15s;
}

.btnDownloadReport:hover {
  background: #4f46e5;
}

/* Empty State */
.emptyState {
  text-align: center;
  padding: 4rem 2rem;
}

.emptyIcon {
  width: 96px;
  height: 96px;
  margin: 0 auto 1.5rem;
  background: #f3f4f6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
  font-size: 48px;
}

.emptyState h3 {
  font-size: 1.25rem;
  color: #111827;
  margin: 0 0 0.5rem 0;
  font-weight: 600;
}

.emptyState p {
  color: #6b7280;
  margin: 0 0 2rem 0;
  font-size: 0.9375rem;
}

/* Loading */
.loading {
  text-align: center;
  padding: 4rem 2rem;
  color: #6b7280;
}

/* Modal Styles */
.modalOverlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  backdrop-filter: blur(4px);
}

.modalContent {
  background: white;
  border-radius: 16px;
  width: 90%;
  max-width: 600px;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
}

.modalHeader {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.5rem;
  border-bottom: 1px solid #e5e7eb;
}

.modalHeader h2 {
  font-size: 1.25rem;
  font-weight: 700;
  color: #111827;
  margin: 0;
}

.closeBtn {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  border: none;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 1.5rem;
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.closeBtn:hover {
  background: #e5e7eb;
  color: #111827;
}

.modalBody {
  padding: 1.5rem;
}

.appointmentInfo {
  background: #f9fafb;
  padding: 1rem;
  border-radius: 8px;
  margin-bottom: 1.5rem;
}

.appointmentInfo h3 {
  font-size: 0.875rem;
  font-weight: 600;
  color: #6b7280;
  margin: 0 0 0.75rem 0;
  text-transform: uppercase;
}

.appointmentInfo p {
  font-size: 0.875rem;
  color: #374151;
  margin: 0.5rem 0;
}

.appointmentInfo strong {
  color: #111827;
  font-weight: 600;
}

.uploadSection {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.fileInputLabel {
  cursor: pointer;
}

.fileInput {
  display: none;
}

.fileInputButton {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  padding: 2rem;
  border: 2px dashed #d1d5db;
  border-radius: 12px;
  background: #f9fafb;
  transition: all 0.2s;
}

.fileInputButton:hover {
  border-color: #6366f1;
  background: #eff6ff;
}

.fileInputButton i {
  font-size: 2rem;
  color: #6366f1;
}

.fileInputButton span {
  font-size: 0.875rem;
  font-weight: 600;
  color: #374151;
}

.selectedFile {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem;
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  border-radius: 8px;
}

.selectedFile i {
  font-size: 1.5rem;
  color: #3b82f6;
}

.selectedFile span {
  font-size: 0.875rem;
  color: #1e40af;
  font-weight: 500;
}

.fileSize {
  margin-left: auto;
  color: #6b7280 !important;
  font-weight: 400 !important;
}

.uploadNote {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.75rem;
  color: #6b7280;
  margin: 0;
}

.uploadWarning {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.875rem;
  color: #d97706;
  background: #fef3c7;
  padding: 0.75rem;
  border-radius: 8px;
  margin: 0;
}

.modalFooter {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 0.75rem;
  padding: 1.5rem;
  border-top: 1px solid #e5e7eb;
}

.btnSecondary {
  padding: 0.625rem 1.25rem;
  background: #f3f4f6;
  color: #374151;
  border: none;
  border-radius: 8px;
  font-size: 0.875rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  font-family: 'Inter', sans-serif;
}

.btnSecondary:hover:not(:disabled) {
  background: #e5e7eb;
}

.btnSecondary:disabled,
.btnPrimary:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Responsive */
@media (max-width: 1024px) {
  .sidebar {
    width: 240px;
  }
  
  .detailsGrid {
    grid-template-columns: 1fr;
  }
  
  .contentHeader {
    padding: 1.25rem 1.5rem;
  }
  
  .appointmentsList {
    padding: 1.25rem 1.5rem;
  }
}

@media (max-width: 768px) {
  .dashboardLayout {
    flex-direction: column;
    height: auto;
  }
  
  .sidebar {
    width: 100%;
    border-right: none;
    border-bottom: 1px solid #e5e7eb;
    max-height: none;
  }
  
  .sidebarHeader {
    padding: 1rem;
  }
  
  .avatarCircle {
    width: 40px;
    height: 40px;
    font-size: 1rem;
  }
  
  .searchSection {
    padding: 0.75rem 1rem;
  }
  
  .statsSection {
    padding: 0.75rem 1rem;
  }
  
  .statsCards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }
  
  .statCard {
    padding: 0.625rem 0.75rem;
  }
  
  .statIconBox {
    width: 32px;
    height: 32px;
    font-size: 0.75rem;
  }
  
  .statLabel {
    font-size: 0.75rem;
  }
  
  .statCount {
    font-size: 1rem;
  }
  
  .filterSection {
    padding: 0.75rem 1rem;
  }
  
  .doctorsList {
    max-height: 200px;
  }
  
  .doctorItem {
    padding: 0.625rem;
  }
  
  .doctorAvatar {
    width: 32px;
    height: 32px;
    font-size: 0.7rem;
  }
  
  .contentHeader {
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem;
  }
  
  .headerLeft h1 {
    font-size: 1.25rem;
  }
  
  .headerLeft p {
    font-size: 0.8rem;
  }
  
  .headerActions {
    width: 100%;
    justify-content: space-between;
  }
  
  .btnPrimary {
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
  }
  
  .appointmentsList {
    padding: 1rem;
  }
  
  .appointmentHeader {
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem;
  }
  
  .appointmentLeft {
    width: 100%;
  }
  
  .appointmentRight {
    width: 100%;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }
  
  .appointmentDateTime {
    text-align: left;
  }
  
  .appointmentDetails {
    padding: 1rem;
  }
  
  .actionButtons {
    flex-direction: column;
  }
  
  .actionButtons button {
    width: 100%;
  }
  
  .notificationDropdown {
    width: calc(100vw - 2rem);
    right: -1rem;
  }
  
  .modalContent {
    width: 95%;
    max-width: none;
  }
  
  .modalHeader,
  .modalBody,
  .modalFooter {
    padding: 1rem;
  }
  
  .modalFooter {
    flex-direction: column;
  }
  
  .modalFooter button {
    width: 100%;
  }
}

@media (max-width: 480px) {
  .sidebarTitle {
    font-size: 0.75rem;
  }
  
  .sidebarSubtitle {
    font-size: 0.7rem;
  }
  
  .statsCards {
    grid-template-columns: 1fr;
  }
  
  .headerLeft h1 {
    font-size: 1.125rem;
  }
  
  .appointmentDoctor {
    font-size: 0.9rem;
  }
  
  .appointmentSpec {
    font-size: 0.8rem;
  }
  
  .statusBadge {
    font-size: 0.7rem;
    padding: 0.25rem 0.625rem;
  }
  
  .detailLabel {
    font-size: 0.7rem;
  }
  
  .detailValue {
    font-size: 0.8rem;
  }
  
  .emptyIcon {
    width: 72px;
    height: 72px;
    font-size: 36px;
  }
  
  .emptyState h3 {
    font-size: 1.125rem;
  }
  
  .emptyState p {
    font-size: 0.875rem;
  }
}
