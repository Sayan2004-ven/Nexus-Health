# Uploads - Don't commit user-uploaded files and generated prescriptions
backend/uploads/prescriptions/*.pdf
backend/uploads/reports/*.pdf

# Keep the directories but not the files
!backend/uploads/prescriptions/.gitkeep
!backend/uploads/reports/.gitkeep

